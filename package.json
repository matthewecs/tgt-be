{
  "name": "tgt-be",
  "version": "1.0.0",
  "description": "TGT Water Treatment Backend Service",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node db/run-sql.js db/schema.sql",
    "db:seed": "node db/run-sql.js db/seed.sql",
    "db:seed:users": "node db/userSeed.js",
    "db:setup": "npm run db:migrate && npm run db:seed && npm run db:seed:users"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
